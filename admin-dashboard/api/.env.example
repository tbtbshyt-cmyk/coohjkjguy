# ============================================================================
#  أبو بشار API — Environment Variables (EXAMPLE)
#  Copy to .env and fill in real values
# ============================================================================

# Runtime
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1/abecp
CORS_ORIGINS=http://localhost:3000,https://abu-bishar.com

# Database (Supabase Postgres URL)
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres?sslmode=require

# JWT
JWT_SECRET=replace-with-64-char-random-string-using-openssl-rand-hex-32
JWT_ACCESS_TTL=900        # 15 min
JWT_REFRESH_TTL=2592000   # 30 days

# Redis (Upstash / Render KeyValue)
REDIS_URL=redis://default:PASSWORD@xxx.upstash.io:6379

# Object Storage (Supabase Storage / S3 / R2)
STORAGE_ENDPOINT=https://xxx.supabase.co/storage/v1
STORAGE_BUCKET=abubishar-media
STORAGE_KEY=eyJhbGciOi...
STORAGE_PUBLIC_URL=https://media.abu-bishar.com

# Payment gateways (future)
STRIPE_SECRET=sk_test_...
PAYPAL_CLIENT_ID=

# WhatsApp / SMS (Twilio or local Yemen SMS gateway)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Admin notification email
ADMIN_EMAIL=tbashyalo566@gmail.com
ADMIN_NOTIFICATIONS=owner@abu-bishar.com

# Image optimization
IMAGE_MAX_WIDTH=1280
IMAGE_QUALITY=82
CDN_BASE_URL=https://media.abu-bishar.com

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Feature flags
ENABLE_AI_ASSISTANT=true
ENABLE_VOICE_SEARCH=false
ENABLE_AR_PREVIEW=false